<Window x:Class="PdfTableExtractor.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:viewModels="clr-namespace:PdfTableExtractor.App.ViewModels"
        xmlns:local="clr-namespace:PdfTableExtractor.App"
        mc:Ignorable="d"
        Title="PDF Table Extractor"
        Height="820" Width="1120"
        WindowStartupLocation="CenterScreen"
        TextElement.FontSize="14"
        Background="{DynamicResource MaterialDesignPaper}">

    <Window.Resources>
        <local:BooleanNegationConverter x:Key="BoolNot" />
    </Window.Resources>

    <Window.DataContext>
        <viewModels:MainViewModel />
    </Window.DataContext>

    <DockPanel LastChildFill="True">

        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" />
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <ProgressBar Width="220" Height="14" Minimum="0" Maximum="100" Value="{Binding ProgressPercent}" />
            </StatusBarItem>
        </StatusBar>

        <Grid Margin="{StaticResource DefaultPadding}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <materialDesign:Card Grid.Row="0" Padding="16" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock FontSize="22" FontWeight="SemiBold" Text="PDF Table Extractor"/>
                    <TextBlock Opacity="0.75" Text="Extract Materials/Tooling tables from PDFs and export to a multi-sheet Excel workbook."/>
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Grid.Row="1" Padding="16" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="3*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock FontWeight="SemiBold" Text="Mode" Margin="0,0,0,8"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <ToggleButton Width="140" Height="40" Margin="0,0,10,0"
                                          Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                          IsChecked="{Binding IsMaterialMode}">
                                <TextBlock Text="Material" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </ToggleButton>

                            <ToggleButton Width="140" Height="40"
                                          Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                          IsChecked="{Binding IsToolingMode}">
                                <TextBlock Text="Tooling" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </ToggleButton>
                        </StackPanel>

                        <TextBlock FontWeight="SemiBold" Text="Input" Margin="0,0,0,8"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Button Style="{StaticResource MaterialDesignRaisedButton}"
                                    Command="{Binding SelectPdfFilesCommand}"
                                    IsEnabled="{Binding IsBusy, Converter={StaticResource BoolNot}}"
                                    Margin="0,0,10,0" Padding="14,8">
                                Select PDF Files
                            </Button>

                            <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Command="{Binding SelectFolderCommand}"
                                    IsEnabled="{Binding IsBusy, Converter={StaticResource BoolNot}}"
                                    Padding="14,8">
                                Select Folder
                            </Button>
                        </StackPanel>

                        <TextBlock FontWeight="SemiBold" Text="Output" Margin="0,12,0,8"/>

                        <Button Style="{StaticResource MaterialDesignRaisedButton}"
                                Command="{Binding SelectOutputFolderCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource BoolNot}}"
                                Padding="14,8" Margin="0,0,0,10">
                            Select Output Folder
                        </Button>

                        <Button Style="{StaticResource MaterialDesignRaisedButton}"
                                Background="#2E7D32" Foreground="White"
                                Command="{Binding StartExtractionCommand}"
                                IsEnabled="{Binding CanStart}"
                                Padding="14,10">
                            Start Extraction
                        </Button>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock FontWeight="SemiBold" Text="Selected PDFs" Margin="0,0,0,8"/>
                        <ListBox ItemsSource="{Binding SelectedPdfFiles}" Height="180"
                                 BorderThickness="1" BorderBrush="{DynamicResource MaterialDesignDivider}" />

                        <TextBlock FontWeight="SemiBold" Text="Output Folder" Margin="0,12,0,8"/>
                        <TextBox Text="{Binding OutputFolder}" IsReadOnly="True"
                                 materialDesign:HintAssist.Hint="Output folder"
                                 BorderThickness="1" BorderBrush="{DynamicResource MaterialDesignDivider}" />
                    </StackPanel>
                </Grid>
            </materialDesign:Card>

            <materialDesign:Card Grid.Row="2" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock FontSize="16" FontWeight="SemiBold" Text="Live Log" DockPanel.Dock="Left"/>
                        <Button Style="{StaticResource MaterialDesignFlatButton}"
                                Command="{Binding ClearLogCommand}"
                                DockPanel.Dock="Right" Padding="12,6"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource BoolNot}}">
                            Clear
                        </Button>
                    </DockPanel>

                    <TextBox Grid.Row="1" Text="{Binding LiveLogText}" IsReadOnly="True"
                             TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto" FontFamily="Consolas"
                             BorderThickness="1" BorderBrush="{DynamicResource MaterialDesignDivider}" />
                </Grid>
            </materialDesign:Card>

        </Grid>
    </DockPanel>
</Window>
